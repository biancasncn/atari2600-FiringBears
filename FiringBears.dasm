; Firing Bears
; Made on 8bitworkshop as a Atari2600 game using assembly 6502
		processor 6502
                include "vcs.h"
                include "macro.h"
                include "xmacro.h"

PF_H            equ #96                	; playfield height - playfied data x 4 -> 4LK

BEAR_H          equ #15                	; bear sprite height
BEAR_F          equ #15                	; Number of frames in the bear animation 0, set to 15 and 3xlsr for faster
MISS_H		equ #3			; missile height

                seg.u vars             	; uninitialized segment
                org $80                	; origin set at base of ram
                
pf_count	.byte			; lines left in playfield segment

p0_y            .byte                   ; 1 byte - player 0 y pos
p1_y            .byte                   ; player 1 y pos
p0_x            .byte                   ; player 0 x pos
p1_x            .byte                   ; player 1 x pos
tp0_y           .byte                   ; temporary player 0 y pos
tp1_y           .byte                   ; temporary player 1 y pos

bear_frame      .byte                   ; current frame of bear animation
bearPtr	        .byte			; points at which frame to be at at

m0_x		.byte
m1_x		.byte
m0_active	.byte
m1_active	.byte
tm0_y       	.byte
tm1_y       	.byte
enam0_r     	.byte          ; ram copy of enam0
enam1_r     	.byte          ; ram copy of enam1

                seg main               
                org $F000

start           CLEAN_START            

                lda #$5b
                sta COLUBK             ; set the BG color
               	
                lda #$ff
                sta COLUPF             ; set the PF color
                lda #1
                sta CTRLPF	       ; make symetric (mirror)

                lda #$76
                sta COLUP0             ; set the P0 color
                lda #$96
                sta COLUP1             ; set the P1 color
                
                lda #215	       ; initial y pos of p0 and p1
                sta p0_y               
                sta p1_y                
                lda #20
                sta p0_x               ; initial x pos of p0
                lda #150
                sta p1_x               ; initial x pos of p1                                              

nextFrame       VERTICAL_SYNC
		sta WSYNC  
                
vblank          ldx #43 
                stx TIM64T
                
                lda p0_x
                ldx #0                 ; P0
                jsr setHorizPos        ; set the initial course position of the player 0 
                
                lda p1_x
                ldx #1                 ; P1
                jsr setHorizPos        ; set the initial course position of the player 1 
                
                lda m0_x	       ; M0
                ldx #0                 
                jsr setHorizPosM  
                
                lda m1_x	       ; M1
                ldx #1                 
                jsr setHorizPosM 
                
                lda #%010000
		sta NUSIZ0
                lda #%010000
		sta NUSIZ1
                
                sta WSYNC	       ; NEED wsync and hmove, so scanline processes left/right movement correctly
                sta HMOVE	       ; if commented out, horizontal movements will be staggered
                
                ; create a pointer to the bear graphic instead of pointing directy to it
                inc bear_frame      
                lda bear_frame     
                and #BEAR_F    	     ; change to #31 and 4xlsr for slower animation    
                sta bear_frame     
                lsr                  ; lsr allow to say which frame animation needs to be in  
                lsr                  ; when and =7, lsr -> f_0, when and >7, lsr -> f_1  
                lsr
                tax    
                ; when bear frames are only set once and the AND is set to the number 15
                ; it guarantees a constant switch between 0-7 being frame 0 and 8-15 being frame 1, bc of the x3 lsr
                
                lda bear_pMSB,x		
                sta bearPtr+1 
                lda bear_pLSB,x       
                sta bearPtr
                
                lda p0_y               
                sta tp0_y             
                lda p1_y             
                sta tp1_y     
                
                lda p0_y
                sta tm0_y
                lda p1_y
                sta tm1_y
                
                ldx #255
                ldy #PF_H
                sty pf_count
                                                
; vblank -> added all the bear and pf graphics 
bearDone        lda INTIM
		bne bearDone
                
                lda #0
                sta WSYNC
                sta VBLANK             ; turn on the beam

kernel          sta WSYNC

                ldx #%00000010
                ldy #0

                stx enam0_r
                stx enam1_r

                inc tm0_y
                beq .draw_m0
                sty enam0_r
.draw_m0
                inc tm1_y
                beq .draw_m1
                sty enam1_r
.draw_m1

                ; P0 sprite
                lda #BEAR_H
                sec
                isb tp0_y
                bcs .draw_p0
                lda #0
.draw_p0        tay
                lda (bearPtr),y
                sta GRP0

                ; P1 sprite
                lda #BEAR_H
                sec
                isb tp1_y
                bcs .draw_p1
                lda #0
.draw_p1        tay
                lda (bearPtr),y
                sta GRP1

                ; apply missile enables
                lda enam0_r
                and m0_active          ; gate by button press
                sta ENAM0
                lda enam1_r
                and m1_active          ; gate by button press
                sta ENAM1
                
                lda PF0_data,x         
                sta PF0                
                lda PF1_data,x        
                sta PF1                
                lda PF2_data,x         
                sta PF2

                dec pf_count
                bne kernel   
                
                ;sta WSYNC 
; kernel end here
	
pf_end		sta WSYNC
		lda #%10                
                sta VBLANK             ; turn off the beam              
                            
overscan        ldx #35
                stx TIM64T
                
                jsr moveJoystick
                
timer		ldx INTIM
		bne timer

                jmp nextFrame          ; jump back up to start the next frame

setHorizPos     sta WSYNC              ; start a new line
                sec                    ; set carry flag
.divLoop      	sbc #15                ; subtract 15
                bcs .divLoop           ; branch until negative
                eor #7                 ; calculate fine offset
                asl                     
                asl                     
                asl                     
                asl                    
                sta RESP0,x            ; fix coarse position
                sta HMP0,x             ; set fine offset
               	rts                    ; return to caller
                
setHorizPosM    sta WSYNC              ; horiz postion for the missiles
                sec	               ; set carry flag
		cpx #1
                beq .divLoopM1	       ; if m1, branch to m1 loop
.divLoopM       sbc #15                ; subtract 15
                bcs .divLoopM          ; branch until negative
                eor #-7                ; calculate fine offset -> M2 only moves to the right
                jmp .store
.divLoopM1      sbc #15                ; subtract 15
                bcs .divLoopM1         ; branch until negative
                eor #7 
.store          asl                     
                asl                     
                asl                     
                asl                     
                sta RESMP0,x           ; fix coarse position to player
                sta HMM0,x             ; set fine offset
               	rts                    ; return to caller                                 

bear_pLSB     	.byte <bear_f0         ; LSB
              	.byte <bear_f1

bear_pMSB     	.byte >bear_f0         ; MSB
		.byte >bear_f1
                
moveJoystick	; Read joystick movement
; reading the input button stuff
		lda #$76               	; color index set to default col
                bit INPT4              	; check player 1 button
                bmi .noPress           	; branch if minus, D7 will be 0 if button is pressed
                lda #%10
            	sta m0_active
                lda #$B0

.noPress	sta COLUP0             ; set the P0 color

		lda #$96               
                bit INPT5              ; player 2 button
                bmi .noPress1 
                lda #%10
            	sta m1_active
                lda #$40

.noPress1	sta COLUP1             ; set the P1 color
		; (up and down are actually reversed since ypos starts at bottom)
                ldx p0_y
                lda #%00100000	
                bit SWCHA
                bne .SkipMoveUp
                cpx #176
                bcc .SkipMoveUp
                dex
                
.SkipMoveUp	lda #%00010000	
                bit SWCHA 
                bne .SkipMoveDown
                cpx #255
                bcs .SkipMoveDown
                inx
                
.SkipMoveDown	stx p0_y 
                ldx p0_x
                lda #%01000000	
                bit SWCHA
                bne .SkipMoveLeft
                cpx #20
                bcc .SkipMoveLeft
                dex
                
.SkipMoveLeft	lda #%10000000	
                bit SWCHA 
                bne .SkipMoveRight
                cpx #80
                bcs .SkipMoveRight
                inx
                
.SkipMoveRight	stx p0_x
		
; move joystick for player 1
                ldx p1_y
                lda #%00000010	
                bit SWCHA
                bne .SkipMoveUp1
                cpx #176
                bcc .SkipMoveUp1
                dex
                
.SkipMoveUp1	lda #%00000001	
                bit SWCHA 
                bne .SkipMoveDown1
                cpx #255
                bcs .SkipMoveDown1
                inx
                
.SkipMoveDown1	stx p1_y
                ldx p1_x
                lda #%00000100	
                bit SWCHA
                bne .SkipMoveLeft1
                cpx #91
                bcc .SkipMoveLeft1
                dex
                
.SkipMoveLeft1 	lda #%00001000	
                bit SWCHA 
                bne .SkipMoveRight1
                cpx #150
                bcs .SkipMoveRight1
                inx
                
.SkipMoveRight1	stx p1_x
                rts		;return to caller               
                                               
PF0_data
                 .byte #%11110000       
                 .byte #%11110000
                 .byte #%01110000		
                 .byte #%00110000
                 .byte #%00110000
                 .byte #%00110000
                 .byte #%00110000
                 .byte #%00110000
                 .byte #%00110000
                 .byte #%00110000
                 .byte #%00110000
                 .byte #%00110000
                 .byte #%00110000
                 .byte #%00110000
                 .byte #%00110000
                 .byte #%00110000
                 .byte #%00110000
                 .byte #%00110000
                 .byte #%00110000
                 .byte #%00110000
                 .byte #%00110000
                 .byte #%01110000
                 .byte #%11110000
                 .byte #%11110000       

PF1_data
                 .byte #%11111111       
                 .byte #%00000000
                 .byte #%00000000
                 .byte #%00000000
                 .byte #%00000000
                 .byte #%00000000
                 .byte #%00000000
                 .byte #%00000000
                 .byte #%00100000
                 .byte #%00100000
                 .byte #%00100000
                 .byte #%00100000
                 .byte #%00100000
                 .byte #%00100000
                 .byte #%00100000
                 .byte #%00100000
                 .byte #%00000000
                 .byte #%00000000
                 .byte #%00000000
                 .byte #%00000000
                 .byte #%00000000
                 .byte #%00000000
                 .byte #%00000000
                 .byte #%11111111       

PF2_data
                 .byte #%11111111       
                 .byte #%00000000
                 .byte #%00000000
                 .byte #%00000000
                 .byte #%00100000
                 .byte #%00110000
                 .byte #%00001001
                 .byte #%00000101
                 .byte #%00000011
                 .byte #%11000000
                 .byte #%11000000
                 .byte #%11000000
                 .byte #%11000000
                 .byte #%11000000
                 .byte #%00000000
                 .byte #%00000011
                 .byte #%00000101
                 .byte #%00001001
                 .byte #%00110000
                 .byte #%00100000
                 .byte #%00000000
                 .byte #%00000000
                 .byte #%00000000
                 .byte #%11111111                                  

bear_f0         .byte $0            
                .byte %01000010
                .byte %01111110
                .byte %01000010
                .byte %10000001
                .byte %10100101
                .byte %10100101
                .byte %01000010
                .byte %00111100
                .byte %01000010
                .byte %10111101
                .byte %10011001
                .byte %10100101
                .byte %01000010
                .byte %11111111
                .byte %11000011

bear_f1        	.byte $0
                .byte %10000001
                .byte %01111110
                .byte %01000010
                .byte %10000001
                .byte %10100101
                .byte %11000011
                .byte %01000010
                .byte %00111100
                .byte %01000010
                .byte %10111101
                .byte %10011001
                .byte %10100101
                .byte %01000010
                .byte %11111111
                .byte %11000011
                

                 org $FFFA

          	.word start            ; NMI  ($FFFA)
              	.word start            ; RESET ($FFFC)
              	.word start            ; IRQ ($FFFE)